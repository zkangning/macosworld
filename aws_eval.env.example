# Source this file before running scripts/run_aws_eval.sh.
# Keep secrets out of git. If you already use ~/.aws/credentials, leave the
# AWS access key variables commented out here.

export AWS_DEFAULT_REGION='ap-southeast-1'
# export AWS_ACCESS_KEY_ID=''
# export AWS_SECRET_ACCESS_KEY=''
# export AWS_SESSION_TOKEN=''

# Pick one provider block as needed.
export OPENAI_API_KEY=''
# export QWEN_BASE_URL='https://maas.devops.xiaohongshu.com/v1'
# export QWEN_API_KEY=''
# export QWEN_THINKING_MODE='auto'
# export ANTHROPIC_API_KEY=''
# export GOOGLE_APPLICATION_CREDENTIALS='/absolute/path/to/gcp-vertex-credential.json'

export MACOSWORLD_CONDA_ENV='macosworld'
export MACOSWORLD_INSTANCE_ID='i-xxxxxxxxxxxxxxxxx'
export MACOSWORLD_SSH_HOST='ec2-xx-xx-xx-xx.ap-southeast-1.compute.amazonaws.com'
export MACOSWORLD_SSH_PKEY='/absolute/path/to/credential.pem'
export MACOSWORLD_GUI_AGENT_NAME='gpt-4o-2024-08-06'
export MACOSWORLD_AGENT_IMAGE_WINDOW='3'

# Space-separated lists.
export MACOSWORLD_PATHS_TO_EVAL_TASKS='./tasks/sys_apps'
export MACOSWORLD_LANGUAGES='task_en_env_en'

export MACOSWORLD_BASE_SAVE_DIR='./results/smoke_gpt4o'
export MACOSWORLD_MAX_STEPS='20'
export MACOSWORLD_SNAPSHOT_RECOVERY_TIMEOUT_SECONDS='1200'
export MACOSWORLD_TASK_STEP_TIMEOUT='120'

# Full benchmark example:
# export MACOSWORLD_PATHS_TO_EVAL_TASKS='./tasks/sys_apps ./tasks/sys_and_interface ./tasks/productivity ./tasks/media ./tasks/file_management ./tasks/advanced ./tasks/multi_apps'
# export MACOSWORLD_LANGUAGES='task_en_env_en task_zh_env_zh task_ar_env_ar task_ja_env_ja task_ru_env_ru'
# export MACOSWORLD_BASE_SAVE_DIR='./results/full_gpt4o'
